# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs — CPR voice on /sos/cpr/assist (server TTS; key never sent to browser)
# Voice ID: ElevenLabs dashboard → Voices → copy a voice ID (not the Conversational Agent ID).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional override (default eleven_turbo_v2_5)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# FastAPI backend used by Web Serial patient-profile handoff
NEXT_PUBLIC_CARDIACLINK_API_URL=http://localhost:8000
# Optional exact override if you do not want to derive from NEXT_PUBLIC_CARDIACLINK_API_URL
# NEXT_PUBLIC_PATIENT_PROFILE_ENDPOINT=http://localhost:8000/api/patient/profile
