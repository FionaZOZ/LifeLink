# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs — CPR voice on /sos/cpr/assist (server TTS; key never sent to browser)
# ELEVENLABS_VOICE_ID is REQUIRED (Voices / Voice library). ELEVENLABS_AGENT_ID does NOT substitute for it.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional override (default eleven_turbo_v2_5 for English)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Chinese TTS defaults to eleven_multilingual_v2 when UI lang is zh; override if needed:
# ELEVENLABS_MODEL_ID_ZH=eleven_multilingual_v2

# MongoDB Atlas (optional - for FHIR handoff persistence and agent telemetry)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=cardiaclink

# FastAPI backend used by Web Serial patient-profile handoff
NEXT_PUBLIC_CARDIACLINK_API_URL=http://localhost:8000
# Optional exact override if you do not want to derive from NEXT_PUBLIC_CARDIACLINK_API_URL
# NEXT_PUBLIC_PATIENT_PROFILE_ENDPOINT=http://localhost:8000/api/patient/profile

# Fetch.ai Bus Event Server (for live telemetry)
BUS_EVENT_URL=http://localhost:8010
NEXT_PUBLIC_BUS_EVENT_URL=http://localhost:8010

# Agentverse hosted agents (4 of them, re-deployed 2026-04-26)
AGENTVERSE_BASE_URL=https://agentverse.ai
AGENTVERSE_API_KEY=your_agentverse_api_key_from_profile_page
COORDINATOR_AGENT_ADDRESS=agent1qf39hy5w480wqetwekxy7z0hf8gkchdddf863thqhxsxsdynvqr9upx5q4f
AED_AGENT_ADDRESS=agent1qfedfdfe9l0cwejgrz30my4gmtjj8xjsam39hjzesa0khlhnsnmfg57k3p0
EMS_AGENT_ADDRESS=agent1qw3239g4tahjmw93fwqqp24hyhelljh70ee6wh59euqgrts0kdqfv8gtdll
HANDOFF_AGENT_ADDRESS=agent1q2z070qakeu20musu62dcegcdykse3kx403tugtc4u09fwgu72gwsg8nc29

# Backend API URL (for health checks)
BACKEND_URL=http://localhost:8000

# Developer Dashboard (production only)
# DEV_DASHBOARD_KEY=your_secret_key
