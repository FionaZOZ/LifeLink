# Agent identity seeds (random strings; deterministic seed = same address each run)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
COORDINATOR_SEED=
VOICE_SEED=
AED_SEED=
EMS_SEED=
HANDOFF_SEED=
OPTIMIZER_SEED=
TRIAGE_SEED=
DRONE_SEED=

# Coordinator + Triage reasoning LLM (REQUIRED for full functionality)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Voice agent (optional in v1; agent runs in stub mode if unset)
# For Next.js CPR voice TTS, set ELEVENLABS_* in .env.local (see .env.local.example).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# EMS agent (optional; falls back to synthesized 3-word string if unset)
WHAT3WORDS_API_KEY=

# AED agent fallback (no key needed for OpenAEDMap public read API)
OPENAEDMAP_BASE_URL=https://openaedmap.org

# Discovery fallback (used only if Almanac discovery fails)
# These should be populated with the actual agent addresses after first run
AED_AGENT_ADDRESS=
EMS_AGENT_ADDRESS=
VOICE_AGENT_ADDRESS=
HANDOFF_AGENT_ADDRESS=
OPTIMIZER_AGENT_ADDRESS=
TRIAGE_AGENT_ADDRESS=
DRONE_AGENT_ADDRESS=

# Event Bus Configuration
# Redis pub/sub for production (optional; falls back to in-memory queues if empty)
BUS_REDIS_URL=

# Event server port (default: 8010)
BUS_EVENT_PORT=8010
